[
  {
    "corsRuleName": "allowLocalhost",
    "allowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://yourdomain.com"
    ],
    "allowedOperations": ["s3_get", "s3_head", "s3_put"],
    "allowedMethods": ["GET", "HEAD", "PUT"],
    "allowedHeaders": ["*"],
    "exposeHeaders": ["ETag"],
    "maxAgeSeconds": 3600
  }
]
